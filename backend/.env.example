# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── External APIs ────────────────────────────────────────
TIMEAPI_BASE_URL=https://timeapi.io/api

# ─── App Timezone ─────────────────────────────────────────
# Default timezone used for display / storage normalization
APP_TIMEZONE=America/Argentina/Buenos_Aires

# ─── CORS ─────────────────────────────────────────────────
# Allowed origin for CORS (use * for development, set explicitly in production)
APP_CORS_ORIGIN=*
